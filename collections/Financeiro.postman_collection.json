    {
      "name": "Busca um Lançamento específico",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code é 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Estrutura completa do lançamento\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property(\"id\");\r",
              "    pm.expect(jsonData).to.have.property(\"journalDate\");\r",
              "    pm.expect(jsonData).to.have.property(\"memo\");\r",
              "    pm.expect(jsonData).to.have.property(\"referenceNo\");\r",
              "    pm.expect(jsonData).to.have.property(\"voucherType\");\r",
              "    pm.expect(jsonData).to.have.property(\"posted\");\r",
              "    pm.expect(jsonData).to.have.property(\"debitAmount\");\r",
              "    pm.expect(jsonData).to.have.property(\"creditAmount\");\r",
              "    pm.expect(jsonData).to.have.property(\"journalEntryLines\");\r",
              "});\r",
              "\r",
              "pm.test(\"Tipos dos campos estão corretos\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.memo).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.posted).to.be.a(\"boolean\");\r",
              "    pm.expect(jsonData.debitAmount).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.creditAmount).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.journalEntryLines).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"Lançamento tem id correto\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.eql(pm.environment.get(\"journal_id\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Lançamento tem linhas de débito e crédito\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.journalEntryLines.length).to.be.at.least(2);\r",
              "});\r",
              "pm.test(\"Débito e crédito são iguais\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.debitAmount).to.eql(jsonData.creditAmount);\r",
              "});\r",
              "\r",
              "pm.test(\"Lançamento tem pelo menos uma linha de débito\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    var debitos = jsonData.journalEntryLines.filter(line => line.drCr === 1);\r",
              "    pm.expect(debitos.length).to.be.at.least(1);\r",
              "});\r",
              "\r",
              "pm.test(\"Lançamento tem pelo menos uma linha de crédito\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    var creditos = jsonData.journalEntryLines.filter(line => line.drCr === 2);\r",
              "    pm.expect(creditos.length).to.be.at.least(1);\r",
              "});\r",
              "pm.test(\"Tempo de resposta menor que 500ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
